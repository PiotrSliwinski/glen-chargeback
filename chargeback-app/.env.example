# ---------- Databricks (leave unset to run on in-memory mock data) ----------
DATABRICKS_HOST=adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abcdef1234567890
# Warehouse auth mode:
#   service-principal  Databricks OAuth M2M — CLIENT_ID/SECRET is a Databricks-
#                      *generated* OAuth secret (Settings > Identity > Service
#                      principals > OAuth secrets).
#   azure-spn          Entra ID service principal (Azure app registration) —
#                      CLIENT_ID/SECRET is its client id + client secret from
#                      the Azure portal, plus ENTRA_TENANT_ID (set below). This
#                      is the usual "SPN client id + password" for a container.
#   azure-cli          your own `az login` identity (dev/test, no secrets).
# Defaults to service-principal when DATABRICKS_CLIENT_SECRET is set, else
# azure-cli. For an Azure-portal SPN secret you MUST set azure-spn explicitly.
# DATABRICKS_AUTH=azure-spn
DATABRICKS_CLIENT_ID=<service-principal-application-id>
DATABRICKS_CLIENT_SECRET=<client-secret>
DBX_SCHEMA=main_dev.cost_reporting
# Force mock mode even with a host configured:
# DAL_MOCK=true

# ---------- Auth: Microsoft Entra ID via NextAuth ----------
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://chargeback.internal.example.com
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Entra group object IDs → app roles (viewer < steward < publisher)
ENTRA_GROUP_VIEWER=
ENTRA_GROUP_STEWARD=
ENTRA_GROUP_PUBLISHER=

# ---------- Local development only ----------
# Skip sign-in entirely and act as a fixed dev user:
# AUTH_DEV_BYPASS=true
# AUTH_DEV_ROLE=publisher   # viewer | steward | publisher

# ---------- App behavior ----------
RECON_TOLERANCE_USD=1

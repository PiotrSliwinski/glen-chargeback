# ---------- Databricks (leave unset to run on in-memory mock data) ----------
DATABRICKS_HOST=adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abcdef1234567890
# Warehouse auth mode:
#   azure            (default) Entra ID token via DefaultAzureCredential — one
#                    mode for every non-interactive Entra scenario, resolved at
#                    runtime with no code change from laptop to cluster:
#                      - local dev:  your own `az login` identity (no secrets)
#                      - container:  set the AZURE_* SPN vars below
#                      - Azure host: workload/managed identity, all AZURE_* unset
#                    The identity must be added to the workspace with access to
#                    the SQL warehouse.
#   databricks-oauth Databricks-native OAuth M2M — DATABRICKS_CLIENT_ID/SECRET is
#                    a Databricks-*generated* OAuth secret (Settings > Identity >
#                    Service principals > OAuth secrets), NOT an Entra credential.
# Defaults to databricks-oauth when DATABRICKS_CLIENT_SECRET is set, else azure.
# DATABRICKS_AUTH=azure
# Entra SPN for azure mode (leave unset for az login / managed identity):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=<service-principal-application-id>
# AZURE_CLIENT_SECRET=<client-secret>
# Only for DATABRICKS_AUTH=databricks-oauth (a Databricks-generated OAuth secret):
# DATABRICKS_CLIENT_ID=<service-principal-application-id>
# DATABRICKS_CLIENT_SECRET=<databricks-oauth-secret>
# Narrow the credential chain if the managed-identity probe adds latency:
# AZURE_TOKEN_CREDENTIALS=prod   # or: dev
DBX_SCHEMA=main_dev.cost_reporting
# Force mock mode even with a host configured:
# DAL_MOCK=true

# ---------- Auth: Microsoft Entra ID via NextAuth ----------
# Interactive user sign-in — a web-app registration, distinct from the AZURE_*
# warehouse SPN above (different app, different flow: authorization-code, not
# DefaultAzureCredential).
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://chargeback.internal.example.com
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Entra group object IDs → app roles (viewer < steward < publisher)
ENTRA_GROUP_VIEWER=
ENTRA_GROUP_STEWARD=
ENTRA_GROUP_PUBLISHER=

# ---------- Local development only ----------
# Skip sign-in entirely and act as a fixed dev user:
# AUTH_DEV_BYPASS=true
# AUTH_DEV_ROLE=publisher   # viewer | steward | publisher

# ---------- App behavior ----------
RECON_TOLERANCE_USD=1

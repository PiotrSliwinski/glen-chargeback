# ---------- Databricks (leave unset to run on in-memory mock data) ----------
DATABRICKS_HOST=adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abcdef1234567890
# Warehouse auth: an Entra ID token via DefaultAzureCredential — resolved at
# runtime with no config change from laptop to cluster:
#   - local dev:  your own `az login` identity (no secrets)
#   - container:  set the AZURE_* SPN vars below
#   - Azure host: workload/managed identity, all AZURE_* unset
# The identity must be added to the workspace with access to the SQL warehouse.
# Entra SPN (leave unset for az login / managed identity):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=<service-principal-application-id>
# AZURE_CLIENT_SECRET=<client-secret>
# Narrow the credential chain if the managed-identity probe adds latency:
# AZURE_TOKEN_CREDENTIALS=prod   # or: dev
DBX_SCHEMA=main_dev.cost_reporting
# Force mock mode even with a host configured:
# DAL_MOCK=true

# ---------- Identity (no user sign-in) ----------
# The app does no user authentication — it runs as one fixed identity. Restrict
# WHO can reach it at the network/platform layer (VPN, Entra Application Proxy,
# App Service authentication), not in-app.
#   APP_ROLE       caps what the app can do; set `viewer` for a read-only deploy
#   APP_USER_EMAIL is recorded as mapped_by on reference-data writes
# All optional (defaults shown):
# APP_ROLE=publisher          # viewer | steward | publisher
# APP_USER=Chargeback App
# APP_USER_EMAIL=chargeback-app@localhost

# ---------- App behavior ----------
RECON_TOLERANCE_USD=1
